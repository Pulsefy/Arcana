{
  "name": "@arcana/types",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./user.types": {
      "types": "./dist/user.types.d.ts",
      "default": "./dist/user.types.js"
    },
    "./profile.types": {
      "types": "./dist/profile.types.d.ts",
      "default": "./dist/profile.types.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.6.2"
  }
}